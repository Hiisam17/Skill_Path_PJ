{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@server/*": ["apps/server/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["apps/*/src/**/*"],
  "exclude": ["node_modules", "dist", "**/dist", "**/build"]
}
